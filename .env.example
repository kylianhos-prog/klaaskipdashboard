# Kopieer dit bestand naar .env en vul je eigen waarden in.
# .env staat in .gitignore en komt dus NOOIT op GitHub.

# Verplicht: je Claude (Anthropic) API-key voor het uitlezen van bestellingen.
ANTHROPIC_API_KEY=sk-ant-...

# Optioneel: welk Claude-model. Standaard claude-opus-4-7 (slim maar duurder).
# Voor lagere kosten: claude-haiku-4-5 of claude-sonnet-4-6.
# CLAUDE_MODEL=claude-haiku-4-5

# Stille modus: bestellingen wel opnemen, maar NIET terugappen naar klanten.
# Handig om live mee te draaien zonder dat klanten automatische berichten krijgen.
# WHATSAPP_AUTOREPLY=false

# Veiligheidsklep tijdens testen: alleen deze nummers krijgen automatische antwoorden.
# Internationale notatie zonder + (Nederland begint met 31). Komma-gescheiden.
# Laat leeg / weglaten om volledig live te gaan (iedereen krijgt antwoord).
# WHATSAPP_ALLOWLIST=31612345678

# Optioneel: poort van het dashboard (standaard 3000).
# PORT=3000

# Thermische bonprinter (auto-print bij iedere nieuwe bestelling).
# PRINTER_DEVICE=/dev/usb/lp0    # standaard voor Pi + USB-printer
# PRINTER_ENABLED=true           # zet op false om print uit te schakelen
# PRINTER_WIDTH=48               # tekens per regel; 48 voor 80mm Font A

# Dagelijks weerbericht (printer rolt 's ochtends 09:00 voor 3 dagen vooruit uit).
# WEATHER_ENABLED=true                # zet op false om uit te zetten
# WEATHER_CRON="0 9 * * *"            # cron-uitdrukking (default 09:00)
# WEATHER_LAT=52.58                   # Westbeemster
# WEATHER_LON=4.93
# WEATHER_LOCATION="De Beemster"
# WEATHER_DAYS=3
